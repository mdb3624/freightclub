{
  "permissions": {
    "allow": [
      "Bash(mvn *)",
      "Bash(java *)",
      "Read(docs/business/stories/*.md)",
      "Bash(rm -rf test-results/evidence/* test-results/shipper-dashboard-home-*)",
      "Bash(npm run *)",
      "Bash(docker compose *)",
      "Bash(rm -rf test-results/evidence/*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(secrets/**)",
      "Bash(curl *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "browser-use"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write(*.sql)",
        "hooks": [
          {
            "type": "command",
            "command": "mvn flyway:validate -f backend/pom.xml"
          }
        ]
      }
    ]
  }
}
