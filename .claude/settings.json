{
  "permissions": {
    "allow": [
      "Bash(mvn *)",
      "Bash(java *)",
      "Read(docs/business/stories/*.md)",
      "Bash(rm -rf test-results/evidence/* test-results/shipper-dashboard-home-*)",
      "Bash(npm run *)",
      "Bash(docker compose *)",
      "Bash(rm -rf test-results/evidence/*)",
      "mcp__browser-use__browser_scroll",
      "mcp__MCP_DOCKER__browser_navigate",
      "mcp__MCP_DOCKER__browser_snapshot",
      "mcp__jira__get_issue",
      "mcp__jira__jql_search",
      "mcp__jira-write__jira_list_transitions",
      "mcp__jira-write__jira_transition_issue",
      "mcp__jira-write__jira_add_comment",
      "mcp__jira-write__jira_add_attachment",
      "mcp__jira-write__jira_create_issue",
      "mcp__jira-write__jira_update_fields"
    ],
    "deny": [
      "Read(.env)",
      "Read(secrets/**)",
      "Bash(curl *)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "browser-use",
    "jira",
    "jira-write",
    "neon"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-deploy-script-duplication.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write(*.sql)",
        "hooks": [
          {
            "type": "command",
            "command": "mvn flyway:validate -f backend/pom.xml"
          }
        ]
      }
    ]
  }
}
