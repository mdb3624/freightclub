# ============================================================================
# FreightClub Environment Configuration Template
#
# Copy to .env for local development, or supply these via your deployment system.
# Depending on the environment, uncomment or set the relevant sections below.
# ============================================================================

# --- ACTIVE PROFILE (required) ---
# Options: dev (development), test (QA environment), prod (production)
SPRING_PROFILES_ACTIVE=dev

# ============================================================================
# DEVELOPMENT ENVIRONMENT (Native JVM + Local PostgreSQL)
# Usage: cd backend && mvn spring-boot:run
# Database: Start with docker compose up -d db (optional) or use local PostgreSQL
# ============================================================================

DB_URL=jdbc:postgresql://localhost:5432/freightclub_db?currentSchema=freightclub
DB_USERNAME=postgres
DB_PASSWORD=N1kk101!

# ============================================================================
# TEST ENVIRONMENT (Docker deployment, self-contained database)
# Usage: docker compose -f docker-compose.test.yml up
# These values are baked into docker-compose.test.yml but can be overridden:
# ============================================================================

# DB_URL=jdbc:postgresql://db-test:5432/freightclub_test?currentSchema=freightclub
# DB_USERNAME=freightclub_runtime
# DB_PASSWORD=freightclub

# ============================================================================
# PRODUCTION ENVIRONMENT (Docker deployment, external Neon database)
# Usage: docker compose -f docker-compose.prod.yml --env-file .env.prod up
# Copy to .env.prod and fill in REAL values — never commit .env.prod
#
# NOTE: DB_URL must include sslmode=require&channelBinding=require for Neon
# ============================================================================

# PRODUCTION ONLY — ALL REQUIRED, NO DEFAULTS:
# DB_URL=jdbc:postgresql://<neon-host>/freightclub_db?currentSchema=freightclub&sslmode=require&channelBinding=require
# DB_USERNAME=<neon_role_name>
# DB_PASSWORD=<neon_role_password>

# ============================================================================
# JWT Authentication (all profiles)
# ============================================================================
APP_JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_ISSUER=freightclub
JWT_AUDIENCE=freightclub-api
JWT_ACCESS_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# ============================================================================
# Port Configuration
# ============================================================================
PORT=8080
FRONTEND_PORT=9090

# ============================================================================
# CORS & Frontend Configuration
# ============================================================================
# Development: http://localhost:5173 (Vite), http://localhost:8080 (dev server)
# Test: http://localhost:5173 (QA environment)
# Production: https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# ============================================================================
# Optional Integrations
# ============================================================================
EMAIL_ENABLED=false
EMAIL_FROM=noreply@freightclub.app

EIA_ENABLED=false
EIA_API_KEY=dnLA3lqSTpjXMf3H5yJHCgkAqftPVUjYkPFI7

# ============================================================================
# Multi-Tenancy (dev/test only)
# ============================================================================
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# ============================================================================
# Docker Configuration (production only)
# ============================================================================
# Used by docker-compose.prod.yml for pulling images from a registry
# IMAGE_TAG=latest
# GCP_REGISTRY=us-central1-docker.pkg.dev/your-gcp-project/freightclub
