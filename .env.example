# ============================================================================
# FreightClub Environment Configuration Template
#
# LOCAL: Copy to .env for local development.
# TEST:  Configuration for backend tests (loaded from .env.test).
# PROD:  Template for production (copy to .env.prod).
# ============================================================================

# --- ACTIVE PROFILE (required) ---
# Options: dev (development), test (QA environment), prod (production)
SPRING_PROFILES_ACTIVE=dev

# ============================================================================
# DEVELOPMENT ENVIRONMENT (Native JVM + Local PostgreSQL)
# Usage: cd backend && mvn spring-boot:run
# ============================================================================

DB_URL=jdbc:postgresql://localhost:5432/freightclub_db?currentSchema=freightclub
DB_USERNAME=postgres
DB_PASSWORD=

# ============================================================================
# JWT Authentication
# ============================================================================
APP_JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_ISSUER=freightclub
JWT_AUDIENCE=freightclub-api
JWT_ACCESS_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# ============================================================================
# Port Configuration
# ============================================================================
PORT=8080
FRONTEND_PORT=9090

# ============================================================================
# CORS & Frontend Configuration
# ============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080

# ============================================================================
# Integrations & API Keys
# ============================================================================
EMAIL_ENABLED=false
EIA_ENABLED=false
EIA_API_KEY=

# ETRADE & GEMINI (Local dev)
ETRADE_CONSUMER_KEY=
ETRADE_CONSUMER_SECRET=
GEMINI_API_KEY=
MODEL=gemini/gemini-1.5-pro

# ============================================================================
# Multi-Tenancy (dev/test only)
# ============================================================================
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
