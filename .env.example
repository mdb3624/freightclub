# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=freightclub
DB_USERNAME=freightclub_runtime
DB_PASSWORD=your_secure_password_here

# Flyway Database Configuration (must be superuser/owner for DDL)
FLYWAY_HOST=localhost
FLYWAY_PORT=5432
FLYWAY_USER=postgres
FLYWAY_PASSWORD=postgres_password_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_here

# Email Configuration (optional)
EMAIL_ENABLED=false
EMAIL_FROM=noreply@freightclub.app

# EIA Configuration (optional)
EIA_ENABLED=false
EIA_API_KEY=your_eia_api_key_here

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173

