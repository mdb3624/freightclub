# ============================================================================
# FreightClub PRODUCTION Environment Configuration
#
# This is a TEMPLATE. Copy to .env.prod and fill in real values.
# NEVER commit .env.prod to source control.
# All values are REQUIRED — there are no defaults for production.
# ============================================================================

SPRING_PROFILES_ACTIVE=prod
PORT=8080

# ============================================================================
# Neon.tech PostgreSQL Configuration
#
# Connection string format:
# jdbc:postgresql://<host>/<dbname>?currentSchema=freightclub&sslmode=require&channelBinding=require
#
# sslmode=require: Requires an encrypted connection
# channelBinding=require: Enables SCRAM-SHA-256 channel binding (Neon security feature)
# ============================================================================

DB_URL=jdbc:postgresql://ep-lively-tree-amv4cqt0-pooler.c-5.us-east-1.aws.neon.tech/freightclub_db?sslmode=require&currentSchema=freightclub
DB_USERNAME=neondb_owner
DB_PASSWORD=npg_H0O3SomrgjPK

# ============================================================================
# JWT Authentication (production must use strong secrets, min 32 chars)
# ============================================================================
APP_JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_ISSUER=freightclub
JWT_AUDIENCE=freightclub-api
JWT_ACCESS_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# ============================================================================
# CORS Configuration (set to your actual domain)
# ============================================================================
CORS_ALLOWED_ORIGINS=https://freightclub.app

# ============================================================================
# Docker Image Configuration
# ============================================================================
# Used by docker-compose.prod.yml to pull images from your container registry
IMAGE_TAG=latest
GCP_REGISTRY=us-central1-docker.pkg.dev/freight-club-495117/freightclub-repo

