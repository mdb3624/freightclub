{
  "mcpServers": {
    "browser-use": {
      "command": "python",
      "args": ["-m", "browser_use.mcp"],
      "env": {
        "BROWSER_USE_HEADLESS": "false"
      }
    },
    "MCP_DOCKER": {
      "command": "docker",
      "args": ["mcp", "gateway", "run", "--profile", "profile"],
      "env": {
        "LOCALAPPDATA": "C:\\Users\\Owner\\AppData\\Local",
        "ProgramData": "C:\\ProgramData",
        "ProgramFiles": "C:\\Program Files"
      },
      "type": "stdio"
    },
    "jira": {
      "command": "C:\\Program Files\\Git\\bin\\bash.exe",
      "args": ["c:/projects/freightclub/scripts/jira-mcp-wrapper.sh"]
    },
    "jira-write": {
      "command": "C:\\Program Files\\Git\\bin\\bash.exe",
      "args": ["c:/projects/freightclub/scripts/jira-write-mcp-wrapper.sh"]
    }
  }
}