FROM node:20
WORKDIR /app

# Install system dependencies required by Chromium/Playwright
RUN apt-get update && apt-get install -y \
  libnss3 libnspr4 libdbus-1-3 libxss1 libasound2 libxrandr2 libatk1.0-0 \
  libatk-bridge2.0-0 libcups2 libxkbcommon0 libpango-1.0-0 libpangoft2-1.0-0 \
  --no-install-recommends && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm ci --legacy-peer-deps && npx playwright install chromium

COPY . .

EXPOSE 9090

ENV VITE_PORT=9090

CMD ["npm", "run", "dev", "--", "--host"]
